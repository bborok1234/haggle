{
  "name": "haggle",
  "version": "0.1.0",
  "description": "AI 네이티브 중고 마켓플레이스 MCP 서버",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "test": "DATABASE_URL=postgresql://postgres:haggle@localhost:5434/haggle_test vitest run",
    "test:watch": "DATABASE_URL=postgresql://postgres:haggle@localhost:5434/haggle_test vitest",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "test:setup": "DATABASE_URL=postgresql://postgres:haggle@localhost:5434/haggle_test pnpm prisma migrate dev",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0"
  }
}
